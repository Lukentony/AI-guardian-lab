# Normalize line endings to LF on commit, checkout as-is
* text=auto

*.py    text eol=lf
*.sh    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.sql   text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.toml  text eol=lf

# Binary files
*.db    binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.gz    binary
*.zip   binary
