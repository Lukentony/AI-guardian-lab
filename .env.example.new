# ============================================
# WORKSPACE & SECURITY
# ============================================
WORKSPACE_DIR=./workspace
EXEC_UID=1000
EXEC_GID=1000

# Senior Feature: Safe Dry-Run by default
# Set to 'true' to enable real shell command execution
SANDBOX_MODE=false

# Senior Feature: Forensic Audit Signing
# Key used to sign the log chain. If missing, API_KEY is used.
LOG_HMAC_KEY=

# API_KEY is REQUIRED (fail-closed: requests are rejected if not set)
# Generate a strong key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=text

# ============================================
# PATTERN LEARNING
# ============================================
PATTERN_CONFIDENCE_THRESHOLD=30
PATTERN_LEARNING_SAMPLE_SIZE=100
